; connect to COM
sprintf2 c '/C=%s' param2

connect c
setflowctrl 3
testlink
if result<2 goto no_connection

; set baudrate at 19200bps
setbaud  19200

:reset
setrts 1
setrts 0

; send file using XMODEM 1k
xmodemsend param3 3
goto end

:no_connection
sprintf2 msg 'Unable to connect to COM%s.\nClose all other terminal windows.' param2
messagebox msg 'Connection error'
closett

:end
; optionally close tera term
; closett
